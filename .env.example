# MonoXAI Environment Configuration
# Copy this file to .env and fill in the values

# Required: Google Gemini API key for AI-powered Root Cause Analysis
GEMINI_API_KEY=your_gemini_api_key_here

# OpenTelemetry Collector endpoint (default: http://localhost:4318)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Quote Service URL for API Gateway (default: http://localhost:5000)
QUOTE_SERVICE_URL=http://localhost:5000

# RabbitMQ credentials (must match infra/otel-collector/config.yaml)
RABBITMQ_USER=telemetry
RABBITMQ_PASSWORD=telemetry_password
