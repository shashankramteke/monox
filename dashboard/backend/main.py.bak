SERVICES = ["api-gateway", "python-service"]
ROUTES = {
    "api-gateway": ["/api/quote", "/api/proxy-slow-quote", "/api/health", "/api/quotes/random", "/api/proxy-quote"],
    "python-service": ["/quote", "/slow-quote", "/quotes/random", "/quotes/search", "/health"],
}
SEVERITIES = ["DEBUG", "INFO", "INFO", "INFO", "WARNING", "ERROR"]
